# Copy to .env in this folder (BTTS project root) and adjust values.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-for-local-dev
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (create database first — see SETUP.md)
POSTGRES_DB=btts_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional: ticket reservation window (minutes)
TICKET_RESERVATION_MINUTES=10
PASSWORD_RESET_OTP_MINUTES=10

# Email — default prints to console (no SMTP needed for local dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For real SMTP, use e.g. django.core.mail.backends.smtp.EmailBackend and set:
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=BTTS <no-reply@btts.local>
FRONTEND_URL=http://localhost:5173

# Chapa payments — leave empty for local dev without real checkout
CHAPA_SECRET_KEY=
CHAPA_BASE_URL=https://api.chapa.co
CHAPA_WEBHOOK_SECRET=
